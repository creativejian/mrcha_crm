# CRM 환경변수 템플릿
# 실제 값은 .env.local 에 채운다 (.env.local 은 gitignore). 이 파일에 시크릿을 넣지 말 것.
# 값은 팀 채널(Discord)로 공유받는다.

# master(Mr.Cha) Supabase Postgres 연결 — crm 스키마(운영) + catalog 스키마(차량) 직접 사용.
# drizzle(db:generate / db:migrate)는 schemaFilter=["crm"]로 crm만 관리. public(앱)/catalog는 불가침.
# Supabase → Project Settings → Database → Connection string → Session pooler (5432)
DATABASE_URL=

# 로컬 API 서버 포트 (기본 8788)
PORT=8788

# CRM 베이스 URL (기본 http://127.0.0.1:5173) — Playwright baseURL 오버라이드용(playwright.config.ts)
CRM_BASE_URL=

# master Supabase 프로젝트 URL (https://<ref>.supabase.co)
# 미설정이면 JWT issuer 검증이 실패해 **모든 인증 요청이 500**이 된다(middleware/auth.ts).
# Storage(서류함)·send-push Edge 호출의 베이스 URL이기도 하다.
SUPABASE_URL=

# Supabase Storage admin 키 (백엔드 전용, 프론트 노출 금지)
# secret key는 신규 API 키 체계의 SECRET 타입 (legacy service_role 대체)
SUPABASE_SECRET_KEY=

# 업무 AI(RAG 생성·임베딩)·서류 자동분류용 Gemini API 키.
# 미설정이면 업무 AI가 조용히 동작하지 않고, 백필 스크립트는 throw한다.
GEMINI_API_KEY=

# (선택) Gemini 릴레이 프록시 URL — 설정 시 supabase/functions/crm-gemini-proxy 경유(서울 리전 핀).
# 미설정이면 Google 직결. prod는 CF Pages Production 환경변수로 설정돼 있다(CF Workers가 HKG 콜로로
# 라우팅되면 Gemini가 차단 지역으로 거부하는 문제 회피 — #144).
GEMINI_PROXY_URL=

# 프론트(Vite) 빌드타임 공개값은 .env.production 이 담당한다(git 추적됨) — 여기 중복 기재하지 않는다.

# 앱 send-push Edge Function 공유 시크릿 (고객 담당자 배정 알림 발송 시 X-Push-Secret 헤더).
# 미설정이면 헤더 없이 호출한다(fail-open) — 앱이 401 강제 전환한 뒤에는 배정 알림이 실패하고
# tail에 `[push] AUTH_FAILED(401)`이 남는다. prod는 CF Pages Production secret으로 등록.
# ⚠️ 값은 메신저·이슈·커밋 어디에도 남기지 말 것(앱 팀이 별도 안전 채널로 전달).
# ⚠️ .env.local에 넣으면 로컬 dev의 배정도 실 푸시가 나간다(PUSH_NOTIFY 게이트는 NODE_ENV=test만
#    기본 off). 로컬에서 배정을 만질 땐 PUSH_NOTIFY=off 를 붙인다.
SEND_PUSH_SECRET=

# 솔루션 견적 계산(파트너 financial-dolim-solution) 릴레이. 미설정 시 /api/solution/calculate 503.
# 개발: https://mc.mrcha.app/api/quotes/calculate (무인증) / 운영: external 엔드포인트 + 키(제프 협의 후).
SOLUTION_QUOTE_API_URL=
SOLUTION_QUOTE_API_KEY=
