# CRM 환경변수 템플릿
# 실제 값은 .env.local 에 채운다 (.env.local 은 gitignore). 이 파일에 시크릿을 넣지 말 것.
# 값은 팀 채널(Discord)로 공유받는다.

# CRM Supabase Postgres 연결 (거울 데이터를 적재할 대상 = CRM 프로젝트)
DATABASE_URL=

# 로컬 API 서버 포트 (기본 8788)
PORT=8788

# CRM 베이스 URL (기본 http://127.0.0.1:5173)
CRM_BASE_URL=

# 차량 거울 sync용 master(Mr.Cha) Supabase PostgREST 접근
# CRM 전용 publishable 키 (소비자 1 = 전용 키 1, 파트너/앱 키와 공유 금지)
MRCHA_MASTER_SUPABASE_URL=
MRCHA_MASTER_PUBLISHABLE_KEY=
