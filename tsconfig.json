{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./client/src/*", "./src/*"],
      "@client/*": ["./client/src/*"]
    },
    "types": ["node", "bun"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src",
    "client/src",
    "functions",
    "tools",
    "test",
    "scripts",
    "drizzle.config.ts",
    "drizzle.config.catalog.ts",
    "client/vite.config.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
