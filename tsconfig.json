{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./client/src/*", "./src/*"],
      "@client/*": ["./client/src/*"]
    },
    "types": ["node", "bun"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src", "client/src", "functions", "drizzle.config.ts", "client/vite.config.ts"]
}
