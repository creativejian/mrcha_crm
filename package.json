{
  "name": "mrcha-crm",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "trap 'kill 0' EXIT; bun run dev:api & bun run dev:client",
    "dev:api": "bun run src/local-dev.ts",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1",
    "dev:ladle": "ladle serve --host 127.0.0.1",
    "build": "vite build --config client/vite.config.ts",
    "build:ladle": "ladle build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier --check package.json tsconfig.json \"*.config.{js,ts}\" \".ladle/config.mjs\" \"test/**/*.ts\" \"tools/**/*.ts\" \"client/src/**/*.test.tsx\" \"client/src/**/*.stories.tsx\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:server": "bun test",
    "knip": "knip --no-config-hints",
    "screenshot:crm": "playwright test tools/crm-screenshot.spec.ts --project=chromium",
    "visual:crm": "playwright test tools/crm-visual.spec.ts --project=chromium",
    "visual:crm:update": "playwright test tools/crm-visual.spec.ts --project=chromium --update-snapshots",
    "test": "bun run test:server && bun run test:unit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull:catalog": "drizzle-kit pull --config=drizzle.config.catalog.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hono/zod-validator": "^0.8.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "lucide-react": "^1.18.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
