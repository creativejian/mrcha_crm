{
  "name": "mrcha-crm",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "trap 'kill 0' EXIT; bun run dev:api & bun run dev:client",
    "dev:api": "bun run src/local-dev.ts",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1",
    "dev:ladle": "ladle serve --host 127.0.0.1",
    "build": "vite build --config client/vite.config.ts",
    "build:ladle": "ladle build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier --check package.json tsconfig.json \"*.config.{js,ts}\" \".ladle/config.mjs\" \"test/**/*.ts\" \"tools/**/*.ts\" \"client/src/**/*.test.tsx\" \"client/src/**/*.stories.tsx\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "knip": "knip --no-config-hints",
    "screenshot:crm": "playwright test tools/crm-screenshot.spec.ts --project=chromium",
    "visual:crm": "playwright test tools/crm-visual.spec.ts --project=chromium",
    "visual:crm:update": "playwright test tools/crm-visual.spec.ts --project=chromium --update-snapshots",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/zod-validator": "^0.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "lucide-react": "^1.14.0",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
  }
}
